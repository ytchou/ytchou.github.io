---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card">
  <h3>{project.title}</h3>
  <p>{project.description}</p>
  <ul class="tags">
    {project.tags.map(tag => <li>{tag}</li>)}
  </ul>
  <div class="links">
    {project.githubUrl && <a href={project.githubUrl} target="_blank" rel="noopener">GitHub</a>}
    {project.liveUrl && <a href={project.liveUrl} target="_blank" rel="noopener">Live</a>}
  </div>
</article>

<style>
  .project-card {
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    padding: 1.5rem;
  }
  .project-card h3 { margin-top: 0; }
  .tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tags li {
    background: rgb(var(--gray-light));
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.85rem;
    color: rgb(var(--gray-dark));
  }
  .links { display: flex; gap: 1rem; margin-top: 1rem; }
</style>
