---
import type { Project } from '../data/projects';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  project: Project;
  lang?: Lang;
}
const { project, lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<article class="group border border-[#E2DBD3] rounded-xl p-5 hover:border-[#C4B8AA] hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 flex flex-col gap-3">
  <h3 class="font-semibold text-gray-900 group-hover:text-[#6B5B47] transition-colors mt-0">{project.title}</h3>
  <p class="text-sm text-gray-500 leading-relaxed flex-1">{project.description}</p>
  <ul class="flex flex-wrap gap-1.5 list-none p-0 m-0">
    {project.tags.map(tag => (
      <li class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">{tag}</li>
    ))}
  </ul>
  <div class="flex gap-3 pt-1">
    {project.githubUrl && (
      <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-gray-500 hover:text-[#6B5B47] transition-colors no-underline">
        {t('projects.github')} ↗
      </a>
    )}
    {project.liveUrl && (
      <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-gray-500 hover:text-[#6B5B47] transition-colors no-underline">
        {t('projects.live')} ↗
      </a>
    )}
  </div>
</article>
