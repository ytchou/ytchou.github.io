---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = ['TypeScript', 'Python', 'React', 'Node.js', 'SQL', 'Docker'];
---

<BaseLayout title="About — Your Name" description="A bit about me.">
  <h1>About</h1>

  <section class="bio">
    <p>
      I'm a software engineer based in [City]. I work on [what you do].
      Previously at [Company/School]. I care about [values/interests].
    </p>
    <p>
      Outside of work, I [hobbies/interests].
    </p>
  </section>

  <section>
    <h2>Skills</h2>
    <ul class="skills">
      {skills.map(skill => <li>{skill}</li>)}
    </ul>
  </section>
</BaseLayout>

<style>
  .bio p { font-size: 1.1rem; line-height: 1.8; color: rgb(var(--gray-dark)); }
  .skills {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .skills li {
    background: rgb(var(--gray-light));
    padding: 0.4rem 1rem;
    border-radius: 6px;
    font-size: 0.95rem;
  }
</style>
