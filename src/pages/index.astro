---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import ProjectCard from '../components/ProjectCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter(p => p.featured);
---

<BaseLayout title="Your Name" description="Software engineer, writer, and builder.">
  <section class="hero">
    <h1>Hi, I'm <span>Your Name</span></h1>
    <p class="tagline">Software engineer. I build things and write about them.</p>
    <div class="cta">
      <a href="/projects">See my work</a>
      <a href="/contact">Get in touch</a>
    </div>
  </section>

  <section class="recent-posts">
    <h2>Recent writing</h2>
    <ul>
      {latestPosts.map(post => (
        <li>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
          <span class="date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </li>
      ))}
    </ul>
    <a href="/blog">All posts →</a>
  </section>

  <section class="featured-projects">
    <h2>Featured projects</h2>
    <div class="project-grid">
      {featuredProjects.map(project => <ProjectCard project={project} />)}
    </div>
    <a href="/projects">All projects →</a>
  </section>
</BaseLayout>

<style>
  .hero { padding: 4rem 0 3rem; }
  .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .hero h1 span { color: var(--accent); }
  .tagline { font-size: 1.2rem; color: rgb(var(--gray)); margin-bottom: 2rem; }
  .cta { display: flex; gap: 1rem; }
  .cta a {
    padding: 0.6rem 1.4rem;
    border-radius: 6px;
    font-weight: 500;
    text-decoration: none;
  }
  .cta a:first-child {
    background: var(--accent);
    color: #fff;
  }
  .cta a:last-child { border: 1px solid rgb(var(--gray-light)); color: rgb(var(--black)); }
  section { margin-bottom: 4rem; }
  ul { list-style: none; padding: 0; }
  li { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgb(var(--gray-light)); }
  .date { color: rgb(var(--gray)); font-size: 0.9rem; }
  .project-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1rem; }
</style>
