---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostCard from '../../../components/BlogPostCard.astro';
import { useTranslations, sortPosts } from '../../../i18n/utils';

const t = useTranslations('zh');

const posts = sortPosts(await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft));
---

<BaseLayout title={`${t('blog.title')} — 周永唐`} description={t('blog.subtitle')}>
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">{t('blog.title')}</h1>
    <p class="text-gray-500">{t('blog.subtitle')}</p>
  </div>
  <div>
    {posts.map(post => (
      <BlogPostCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        id={post.id}
        pinned={post.data.pinned}
        lang="zh"
      />
    ))}
  </div>
</BaseLayout>
