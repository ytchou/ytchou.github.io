---
import BaseLayout from './BaseLayout.astro';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}
const { title, description, date, tags } = Astro.props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
  <article>
    <header>
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formatted}</time>
      <ul class="tags">
        {tags.map(tag => <li>{tag}</li>)}
      </ul>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  header { margin-bottom: 2rem; border-bottom: 1px solid rgb(var(--gray-light)); padding-bottom: 1.5rem; }
  h1 { margin-bottom: 0.5rem; }
  time { color: rgb(var(--gray)); font-size: 0.9rem; }
  .tags { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.75rem; }
  .tags li { background: rgb(var(--gray-light)); padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem; color: rgb(var(--gray)); }
  .prose { line-height: 1.8; font-size: 1.05rem; }
  .prose h2, .prose h3 { margin-top: 2rem; }
</style>
